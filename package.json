    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "xo": {
    "ignores": [
      "**/*.test.ts",
      "vitest.config.ts"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.4",
